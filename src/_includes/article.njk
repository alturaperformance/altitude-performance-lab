{% extends "base.njk" %}

{% block jsonld %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "@id": "{{ site.url }}{{ page.url }}#article",
      "headline": {{ title | dump | safe }},
      "description": {{ description | dump | safe }},
      "datePublished": "{{ date | dateISO }}",
      "dateModified": "{{ updated | dateISO if updated else date | dateISO }}",
      "author": {
        "@type": "Organization",
        "@id": "{{ site.url }}/#organization",
        "name": {{ site.name | dump | safe }}
      },
      "publisher": {
        "@type": "Organization",
        "@id": "{{ site.url }}/#organization",
        "name": {{ site.name | dump | safe }},
        "url": "{{ site.url }}"
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "{{ site.url }}{{ page.url }}"
      }{% if ogImage %},
      "image": {
        "@type": "ImageObject",
        "url": "{{ site.url }}{{ ogImage }}"
      }{% endif %}
    },
    {
      "@type": "BreadcrumbList",
      "@id": "{{ site.url }}{{ page.url }}#breadcrumb",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "{{ site.url }}/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Articles",
          "item": "{{ site.url }}/articles/"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": {{ title | dump | safe }},
          "item": "{{ site.url }}{{ page.url }}"
        }
      ]
    }
  ]
}
</script>
{% endblock %}

{% block content %}
<div class="article-layout">

  <nav class="article-breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a>
    <span class="article-breadcrumb-sep">/</span>
    <a href="/articles/">Articles</a>
    <span class="article-breadcrumb-sep">/</span>
    <span aria-current="page">{{ title }}</span>
  </nav>

  <article>
    <header>
      {% if category %}
      <span class="article-category-tag">{{ category }}</span>
      {% endif %}

      <h1 class="article-title">{{ title }}</h1>

      {% if description %}
      <p class="article-description">{{ description }}</p>
      {% endif %}

      <div class="article-meta">
        <time datetime="{{ date | dateISO }}">{{ date | dateDisplay }}</time>
        {% if readingTime %}<span>{{ readingTime }} min read</span>{% endif %}
        {% if tags and tags.length %}
        <div class="article-tags">
          {% for tag in tags %}
          {% if tag != "articles" %}
          <a href="/tags/{{ tag | slugify }}/" class="article-tag">{{ tag }}</a>
          {% endif %}
          {% endfor %}
        </div>
        {% endif %}
      </div>
    </header>

    <div class="prose">
      {{ content | safe }}
    </div>

    <footer class="article-footer">
      <p>Published by <strong>{{ site.name }}</strong> · <a href="/articles/">More articles</a></p>
    </footer>
  </article>

</div>
{% endblock %}
