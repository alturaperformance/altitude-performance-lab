<!DOCTYPE html>
<html lang="{{ site.language }}">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>{% if title %}{{ title }} | {{ site.name }}{% else %}{{ site.name }}{% endif %}</title>
  <meta name="description" content="{{ description or site.description }}" />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href="{{ site.url }}{{ page.url }}" />
  {% if site.googleSiteVerification %}
  <meta name="google-site-verification" content="{{ site.googleSiteVerification }}" />
  {% endif %}

  {# Open Graph #}
  <meta property="og:type" content="{{ ogType or 'website' }}" />
  <meta property="og:site_name" content="{{ site.name }}" />
  <meta property="og:title" content="{{ title or site.name }}" />
  <meta property="og:description" content="{{ description or site.description }}" />
  <meta property="og:url" content="{{ site.url }}{{ page.url }}" />
  {% if ogImage %}
  <meta property="og:image" content="{{ site.url }}{{ ogImage }}" />
  <meta property="og:image:alt" content="{{ ogImageAlt or title }}" />
  {% endif %}

  {# Twitter Card #}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="{{ site.social.twitter }}" />
  <meta name="twitter:title" content="{{ title or site.name }}" />
  <meta name="twitter:description" content="{{ description or site.description }}" />
  {% if ogImage %}
  <meta name="twitter:image" content="{{ site.url }}{{ ogImage }}" />
  {% endif %}

  {# RSS #}
  <link rel="alternate" type="application/rss+xml" title="{{ site.name }} RSS Feed" href="{{ site.url }}/feed.xml" />

  {# Existing site stylesheet — dark theme #}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/styles.css" />

  {# Article-specific styles #}
  <style>
    .article-layout { max-width: 760px; margin: 0 auto; padding: calc(var(--nav-height, 72px) + 48px) 1.5rem 80px; }
    .article-breadcrumb { display: flex; gap: 8px; align-items: center; font-size: 0.8125rem; color: var(--text-muted); margin-bottom: 32px; flex-wrap: wrap; }
    .article-breadcrumb a { color: var(--text-muted); text-decoration: none; transition: color 0.2s; }
    .article-breadcrumb a:hover { color: var(--accent); }
    .article-breadcrumb-sep { opacity: 0.4; }
    .article-category-tag { display: inline-block; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--accent); background: var(--accent-dim); border: 1px solid rgba(0,180,216,0.25); border-radius: var(--radius-sm, 4px); padding: 3px 10px; margin-bottom: 16px; }
    .article-title { font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 800; line-height: 1.2; letter-spacing: -0.02em; color: var(--text-primary); margin-bottom: 16px; }
    .article-description { font-size: 1.1rem; color: var(--text-secondary); line-height: 1.65; margin-bottom: 20px; }
    .article-meta { display: flex; gap: 16px; flex-wrap: wrap; font-size: 0.8125rem; color: var(--text-muted); margin-bottom: 40px; padding-bottom: 32px; border-bottom: 1px solid var(--border); }
    .article-tags { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 0; }
    .article-tag { font-size: 0.75rem; color: var(--text-muted); border: 1px solid var(--border); border-radius: var(--radius-sm, 4px); padding: 2px 8px; text-decoration: none; transition: all 0.2s; }
    .article-tag:hover { border-color: var(--accent); color: var(--accent); }
    /* Prose */
    .prose { color: var(--text-secondary); line-height: 1.8; }
    .prose h2 { font-size: 1.5rem; font-weight: 700; color: var(--text-primary); margin: 2.5rem 0 0.75rem; letter-spacing: -0.01em; }
    .prose h3 { font-size: 1.2rem; font-weight: 600; color: var(--text-primary); margin: 2rem 0 0.6rem; }
    .prose h4 { font-size: 1rem; font-weight: 600; color: var(--text-primary); margin: 1.5rem 0 0.5rem; }
    .prose p { margin-bottom: 1.25rem; }
    .prose a { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }
    .prose a:hover { color: var(--accent-dark, #0096B4); }
    .prose strong { font-weight: 700; color: var(--text-primary); }
    .prose ul, .prose ol { padding-left: 1.75rem; margin-bottom: 1.25rem; }
    .prose li { margin-bottom: 0.4rem; }
    .prose blockquote { border-left: 3px solid var(--accent); padding: 1rem 1.25rem; margin: 1.5rem 0; color: var(--text-secondary); font-style: italic; background: var(--bg-secondary); border-radius: 0 var(--radius-sm, 4px) var(--radius-sm, 4px) 0; }
    .prose pre { background: var(--bg-secondary); border: 1px solid var(--border); border-radius: var(--radius, 8px); padding: 1rem 1.25rem; overflow-x: auto; font-family: var(--font-mono); font-size: 0.875rem; margin: 1.5rem 0; }
    .prose code { font-family: var(--font-mono); font-size: 0.875em; background: var(--bg-secondary); border: 1px solid var(--border); border-radius: var(--radius-sm, 4px); padding: 0.1em 0.35em; color: var(--accent); }
    .prose pre code { background: none; border: none; padding: 0; color: var(--text-primary); }
    .prose table { width: 100%; border-collapse: collapse; margin: 1.5rem 0; font-size: 0.9375rem; }
    .prose th { background: var(--bg-secondary); color: var(--text-primary); padding: 0.65rem 0.85rem; text-align: left; font-weight: 600; border: 1px solid var(--border); }
    .prose td { border: 1px solid var(--border); padding: 0.65rem 0.85rem; color: var(--text-secondary); }
    .prose tr:nth-child(even) td { background: var(--bg-secondary); }
    .prose hr { border: none; border-top: 1px solid var(--border); margin: 2.5rem 0; }
    .article-footer { margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--border); font-size: 0.875rem; color: var(--text-muted); }
    /* Articles index */
    .articles-grid { display: grid; gap: 1rem; margin-top: 2rem; }
    .article-card { background: var(--bg-secondary); border: 1px solid var(--border); border-radius: var(--radius, 8px); padding: 1.5rem; transition: border-color 0.2s, box-shadow 0.2s; }
    .article-card:hover { border-color: var(--accent); box-shadow: 0 0 0 1px var(--accent-dim); }
    .article-card h2 { font-size: 1.1rem; font-weight: 600; margin: 0.4rem 0 0.6rem; }
    .article-card h2 a { text-decoration: none; color: var(--text-primary); }
    .article-card h2 a:hover { color: var(--accent); }
    .article-card p { font-size: 0.9rem; color: var(--text-secondary); margin: 0 0 0.75rem; line-height: 1.6; }
    .article-card-meta { font-size: 0.8rem; color: var(--text-muted); }
    @media (min-width: 640px) { .articles-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (min-width: 1024px) { .articles-grid { grid-template-columns: repeat(3, 1fr); } }
  </style>

  {# JSON-LD structured data #}
  {% block jsonld %}{% endblock %}
</head>
<body>
  <a href="#main" class="skip-link" style="position:absolute;top:-100%;left:0;padding:0.5rem 1rem;background:var(--accent);color:#000;font-weight:600;z-index:1000;text-decoration:none;">Skip to main content</a>

  <!-- NAV -->
  <nav class="nav" role="navigation" aria-label="Main navigation">
    <div class="nav__inner">
      <a href="/" class="nav__logo" aria-label="Altitude Performance Lab home">
        <div class="nav__logo-mark">APL</div>
        <span class="nav__logo-text">Altitude<span>Performance</span>Lab</span>
      </a>
      <ul class="nav__links">
        <li><a href="/">Home</a></li>
        <li><a href="/performance.html">Performance</a></li>
        <li><a href="/nutrition.html">Nutrition</a></li>
        <li><a href="/resources.html">Resources</a></li>
        <li><a href="/articles/">Articles</a></li>
      </ul>
      <button class="nav__hamburger" id="nav-hamburger" aria-label="Open menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>
  <div class="nav__mobile" id="nav-mobile" role="navigation" aria-label="Mobile navigation">
    <a href="/">Home</a>
    <a href="/performance.html">Performance</a>
    <a href="/nutrition.html">Nutrition</a>
    <a href="/resources.html">Resources</a>
    <a href="/articles/">Articles</a>
    <a href="/calculator/dist/index.html" class="btn btn--primary" style="margin-top: 8px;">Try the Calculator →</a>
  </div>

  <main id="main">
    {% block content %}{% endblock %}
  </main>

  <footer class="footer" role="contentinfo">
    <div class="container">
      <div class="footer__inner">
        <div class="footer__brand">
          <a href="/" class="footer__logo" aria-label="Altitude Performance Lab home">
            <div class="footer__logo-mark">APL</div>
            <span class="footer__logo-text">Altitude<span>Performance</span>Lab</span>
          </a>
          <p>Science-backed tools and resources to help athletes understand and conquer altitude's impact on performance.</p>
          <a href="https://alturaperformance.com" class="footer__powered" target="_blank" rel="noopener">
            <span class="footer__powered-label">Powered by</span>Altura Performance
          </a>
        </div>
        <div>
          <div class="footer__col-title">Topic Hubs</div>
          <ul class="footer__links">
            <li><a href="/performance.html">Performance</a></li>
            <li><a href="/nutrition.html">Nutrition</a></li>
            <li><a href="/articles/">Articles</a></li>
          </ul>
        </div>
        <div>
          <div class="footer__col-title">Resources</div>
          <ul class="footer__links">
            <li><a href="/resources.html">All Resources</a></li>
            <li><a href="/calculator/dist/index.html">Performance Calculator</a></li>
            <li><a href="/terms.html">Terms of Use</a></li>
          </ul>
        </div>
      </div>
      <div class="footer__bottom">
        <span class="footer__copyright">© {{ site.buildYear }} {{ site.name }}. All rights reserved.</span>
        <span class="footer__copyright"><a href="/terms.html" style="color: var(--text-muted); text-decoration: none;">Terms of Use</a></span>
      </div>
    </div>
  </footer>

  <script src="/js/calculators.js"></script>
</body>
</html>
