---
layout: base.njk
title: Articles
description: Evidence-based articles on altitude training, acclimatization, VO2 max, and performance optimization for athletes.
ogType: website
---

{% block content %}
<div class="articles-page">
  <div class="container">
    <h1>Articles</h1>
    <p class="page-description">Evidence-based guides on altitude training, acclimatization, and athletic performance.</p>

    {% if collections.articles.length %}
    <ul class="article-list">
      {% for article in collections.articles %}
      <li class="article-card">
        {% if article.data.category %}
        <p class="card-category">{{ article.data.category }}</p>
        {% endif %}
        <h2><a href="{{ article.url }}">{{ article.data.title }}</a></h2>
        {% if article.data.description %}
        <p>{{ article.data.description }}</p>
        {% endif %}
        <p class="card-meta">
          <time datetime="{{ article.date | dateISO }}">{{ article.date | dateDisplay }}</time>
        </p>
      </li>
      {% endfor %}
    </ul>
    {% else %}
    <p>No articles yet — check back soon.</p>
    {% endif %}
  </div>
</div>
{% endblock %}
