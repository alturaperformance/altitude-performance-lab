---
layout: base.njk
title: Altitude Performance Lab
description: Evidence-based training science for athletes who train and compete at altitude. Tools, guides, and research on altitude acclimatization, VO2 max, and performance optimization.
ogType: website
---

{% block jsonld %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": "{{ site.url }}/#website",
  "name": "{{ site.name }}",
  "url": "{{ site.url }}/",
  "description": "{{ site.description }}",
  "publisher": {
    "@type": "Organization",
    "@id": "{{ site.url }}/#organization",
    "name": "{{ site.name }}",
    "url": "{{ site.url }}"
  },
  "potentialAction": {
    "@type": "SearchAction",
    "target": "{{ site.url }}/articles/?q={search_term_string}",
    "query-input": "required name=search_term_string"
  }
}
</script>
{% endblock %}

{% block content %}
<section class="home-hero">
  <div class="container">
    <h1>Train Smarter at Altitude</h1>
    <p>Evidence-based guides, calculators, and research for athletes who live, train, and compete at elevation.</p>
    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
      <a href="/articles/" class="btn btn-primary">Read Articles</a>
      <a href="/tools/" class="btn btn-outline">Free Tools</a>
    </div>
  </div>
</section>

<section class="home-section">
  <div class="container">
    <h2>Latest Articles</h2>
    <p style="color:var(--color-text-muted);margin-bottom:1.5rem;">The latest research and practical guides from our team.</p>

    {% set recentArticles = collections.articles | slice(0, 6) %}
    {% if recentArticles.length %}
    <ul class="article-list">
      {% for article in recentArticles %}
      <li class="article-card">
        {% if article.data.category %}
        <p class="card-category">{{ article.data.category }}</p>
        {% endif %}
        <h2><a href="{{ article.url }}">{{ article.data.title }}</a></h2>
        {% if article.data.description %}
        <p>{{ article.data.description }}</p>
        {% endif %}
        <p class="card-meta">
          <time datetime="{{ article.date | dateISO }}">{{ article.date | dateDisplay }}</time>
        </p>
      </li>
      {% endfor %}
    </ul>
    <p style="margin-top:2rem;"><a href="/articles/" style="color:var(--color-primary);font-weight:600;">View all articles &rarr;</a></p>
    {% else %}
    <p style="color:var(--color-text-muted);">Articles coming soon.</p>
    {% endif %}
  </div>
</section>
{% endblock %}
