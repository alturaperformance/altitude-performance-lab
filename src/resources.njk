---
permalink: /resources.html
title: "Altitude Training Resources | Science, Training & Nutrition Guides"
description: "Expert guides on altitude training, acclimatization, nutrition at elevation, and the physiology behind altitude performance. Evidence-based resources for serious athletes."
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- SEO -->
  <title>Altitude Training Resources | Science, Training &amp; Nutrition Guides | Altitude Performance Lab</title>
  <meta name="description" content="Expert guides on altitude training, acclimatization, nutrition at elevation, and the physiology behind altitude performance. Evidence-based resources for serious athletes.">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="https://altitudeperformancelab.com/resources.html">

  <!-- Open Graph -->
  <meta property="og:type"        content="website">
  <meta property="og:title"       content="Altitude Training Resources | Altitude Performance Lab">
  <meta property="og:description" content="Science-backed guides on altitude training, acclimatization, and nutrition for endurance athletes.">
  <meta property="og:url"         content="https://altitudeperformancelab.com/resources.html">

  <!-- RSS -->
  <link rel="alternate" type="application/rss+xml" title="Altitude Performance Lab RSS Feed" href="/feed.xml">

  <!-- Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Altitude Performance Lab — Resources",
    "url": "https://altitudeperformancelab.com/resources.html",
    "description": "Expert guides on altitude training, acclimatization, nutrition, and the science of altitude performance.",
    "publisher": {
      "@type": "Organization",
      "name": "Altitude Performance Lab",
      "url": "https://altitudeperformancelab.com"
    }
  }
  </script>

  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>

  <!-- ============================================================
       NAVIGATION
       ============================================================ -->
  <nav class="nav" role="navigation" aria-label="Main navigation">
    <div class="nav__inner">
      <a href="/index.html" class="nav__logo" aria-label="Altitude Performance Lab home">
        <div class="nav__logo-mark">APL</div>
        <span class="nav__logo-text">Altitude<span>Performance</span>Lab</span>
      </a>

      <ul class="nav__links">
        <li><a href="/index.html">Home</a></li>
        <li><a href="/performance.html">Performance</a></li>
        <li><a href="/nutrition.html">Nutrition</a></li>
        <li><a href="/resources.html">Resources</a></li>
      </ul>

      <div class="nav__cta">
        <a href="/calculator/dist/index.html" class="btn btn--primary btn--sm">Try the Calculator →</a>
      </div>

      <button class="nav__hamburger" id="nav-hamburger" aria-label="Open menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <div class="nav__mobile" id="nav-mobile" role="navigation" aria-label="Mobile navigation">
    <a href="/index.html">Home</a>
    <a href="/performance.html">Performance</a>
    <a href="/nutrition.html">Nutrition</a>
    <a href="/resources.html">Resources</a>
    <a href="/calculator/dist/index.html" class="btn btn--primary" style="margin-top: 8px;">Try the Calculator →</a>
  </div>


  <!-- ============================================================
       PAGE HERO
       ============================================================ -->
  <section class="page-hero" aria-labelledby="resources-page-heading">
    <div class="container">
      <div class="page-hero__inner">
        <span class="label">Research &amp; Guides</span>
        <h1 id="resources-page-heading" style="margin-top: 12px; margin-bottom: 16px;">
          Altitude Performance Resources
        </h1>
        <p style="font-size: 1.0625rem; max-width: 580px;">
          Evidence-based guides covering the science, training, and nutrition of altitude performance.
          Rigorous enough for serious athletes — clear enough for anyone.
        </p>
      </div>
    </div>
  </section>


  <!-- ============================================================
       FEATURED ARTICLE (Hero card)
       ============================================================ -->
  {% set featured = null %}
  {% for article in collections.articles %}
    {% if article.fileSlug == "altitude-training-vo2-max-improvement" %}
      {% set featured = article %}
    {% endif %}
  {% endfor %}
  {% if not featured %}
    {% set featured = collections.articles | first %}
  {% endif %}

  {% if featured %}
  <section style="padding: 0 0 48px;" aria-labelledby="featured-heading">
    <div class="container">
      <div style="background: var(--bg-secondary); border: 1px solid var(--border); border-radius: var(--radius-xl); overflow: hidden; display: grid; grid-template-columns: 1fr 1fr; align-items: center;" class="featured-article-card">

        <!-- Visual side -->
        <div style="background: linear-gradient(135deg, rgba(0,180,216,0.08) 0%, var(--bg-tertiary) 100%); padding: 56px 48px; border-right: 1px solid var(--border); height: 100%; display: flex; flex-direction: column; justify-content: center;">
          <div style="font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.1em; color: var(--accent); margin-bottom: 24px;">EDITOR'S PICK</div>

          <!-- Mini data viz -->
          <div style="display: flex; flex-direction: column; gap: 14px;">
            <div>
              <div style="display: flex; justify-content: space-between; font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-muted); margin-bottom: 6px;">
                <span>Sea Level (0 ft)</span><span>VO₂ Max: Baseline</span>
              </div>
              <div style="height: 6px; background: var(--bg-primary); border-radius: 3px; overflow: hidden;">
                <div style="width: 100%; height: 100%; background: var(--accent); border-radius: 3px;"></div>
              </div>
            </div>
            <div>
              <div style="display: flex; justify-content: space-between; font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-muted); margin-bottom: 6px;">
                <span>5,000 ft (1,524 m)</span><span>−3.6%</span>
              </div>
              <div style="height: 6px; background: var(--bg-primary); border-radius: 3px; overflow: hidden;">
                <div style="width: 96%; height: 100%; background: var(--accent); opacity: 0.85; border-radius: 3px;"></div>
              </div>
            </div>
            <div>
              <div style="display: flex; justify-content: space-between; font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-muted); margin-bottom: 6px;">
                <span>8,000 ft (2,438 m)</span><span>−9.8%</span>
              </div>
              <div style="height: 6px; background: var(--bg-primary); border-radius: 3px; overflow: hidden;">
                <div style="width: 90%; height: 100%; background: var(--warning); border-radius: 3px;"></div>
              </div>
            </div>
            <div>
              <div style="display: flex; justify-content: space-between; font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-muted); margin-bottom: 6px;">
                <span>12,000 ft (3,658 m)</span><span>−18.2%</span>
              </div>
              <div style="height: 6px; background: var(--bg-primary); border-radius: 3px; overflow: hidden;">
                <div style="width: 81%; height: 100%; background: var(--danger); border-radius: 3px;"></div>
              </div>
            </div>
            <div>
              <div style="display: flex; justify-content: space-between; font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-muted); margin-bottom: 6px;">
                <span>18,000 ft (5,486 m)</span><span>−31.5%</span>
              </div>
              <div style="height: 6px; background: var(--bg-primary); border-radius: 3px; overflow: hidden;">
                <div style="width: 68%; height: 100%; background: var(--danger); opacity: 0.7; border-radius: 3px;"></div>
              </div>
            </div>
          </div>
          <p style="font-size: 0.75rem; color: var(--text-muted); margin-top: 20px; font-family: var(--font-mono);">VO₂ max reduction by altitude — Wehrlin &amp; Hallen, 2006</p>
        </div>

        <!-- Content side -->
        <div style="padding: 48px;">
          <div style="font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.1em; color: var(--accent); margin-bottom: 16px; display: flex; align-items: center; gap: 8px;">
            <span>🧬</span> Training Science
          </div>
          <h2 id="featured-heading" style="font-size: 1.625rem; margin-bottom: 16px; line-height: 1.3;">
            {{ featured.data.title }}
          </h2>
          <p style="margin-bottom: 28px; line-height: 1.7;">
            {{ featured.data.description }}
          </p>
          <div style="display: flex; align-items: center; gap: 16px; flex-wrap: wrap;">
            <a href="{{ featured.url }}" class="btn btn--primary">Read Article →</a>
            <span class="badge badge--accent">Featured</span>
          </div>
        </div>

      </div>
    </div>
  </section>
  {% endif %}


  <!-- ============================================================
       ARTICLE GRID
       ============================================================ -->
  <section class="section" style="padding-top: 24px;" aria-labelledby="all-articles-heading">
    <div class="container">

      <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 32px;">
        <h2 id="all-articles-heading" style="font-size: 1.375rem;">All Articles ({{ collections.articles | length }})</h2>
      </div>

      <!-- Filter buttons -->
      <div class="resources-filters" role="group" aria-label="Filter articles by category">
        <button class="filter-btn active" data-filter="all">All</button>
        <button class="filter-btn" data-filter="acclimatization">🏔️ Acclimatization</button>
        <button class="filter-btn" data-filter="training">🏃 Training</button>
        <button class="filter-btn" data-filter="nutrition">🥗 Nutrition &amp; Supplements</button>
        <button class="filter-btn" data-filter="science">🧬 Science &amp; Research</button>
      </div>

      <!-- Article grid -->
      <div class="articles-grid" id="articles-grid">

        {% for article in collections.articles %}
          {% if article.data.title %}
            {# Determine display category from slug keywords #}
            {% set slug = article.fileSlug %}
            {% set displayCat = "training" %}
            {% set displayIcon = "🏃" %}
            {% set displayLabel = "Training" %}

            {# Acclimatization #}
            {% if "acclimatiz" in slug or "altitude-sickness" in slug or "altitude-sleep" in slug
                or "headache" in slug or "re-acclimatiz" in slug
                or "how-long-acclimatize" in slug or "how-to-acclimatize" in slug
                or "jet-lag" in slug or "altitude-gut" in slug
                or "altitude-blood-pressure" in slug %}
              {% set displayCat = "acclimatization" %}
              {% set displayIcon = "🏔️" %}
              {% set displayLabel = "Acclimatization" %}

            {# Nutrition & Supplements #}
            {% elif "nutrition" in slug or "hydration" in slug or "iron" in slug
                or "caffeine" in slug or "carbohydrate" in slug or "protein" in slug
                or "ketone" in slug or "vitamin" in slug or "sauna" in slug
                or "compression" in slug or "acetazolamide" in slug
                or "cold-water-immersion" in slug %}
              {% set displayCat = "nutrition" %}
              {% set displayIcon = "🥗" %}
              {% set displayLabel = "Nutrition &amp; Supplements" %}

            {# Science & Research #}
            {% elif "vo2" in slug or "epo" in slug or "blood-oxygen" in slug
                or "hemoglobin" in slug or "hrv" in slug or "pulse-oximeter" in slug
                or "breathing" in slug or "hypoxic-training" in slug
                or "normobaric" in slug or "cognitive" in slug
                or "intermittent-hypoxic" in slug or "altitude-mask" in slug
                or "altitude-tent" in slug or "wearables" in slug
                or "altitude-training-epo" in slug or "heat-vs-altitude" in slug
                or "cold-exposure-vs" in slug %}
              {% set displayCat = "science" %}
              {% set displayIcon = "🧬" %}
              {% set displayLabel = "Science &amp; Research" %}
            {% endif %}

            <article class="article-card" data-category="{{ displayCat }}">
              <div class="article-card__body">
                <div class="article-card__category"><span>{{ displayIcon }}</span> {{ displayLabel | safe }}</div>
                <h3>{{ article.data.title }}</h3>
                {% if article.data.description %}
                  <p>{{ article.data.description | truncate(160) }}</p>
                {% endif %}
                <div class="article-card__meta">
                  <a href="{{ article.url }}" class="btn btn--ghost btn--sm">Read →</a>
                </div>
              </div>
            </article>
          {% endif %}
        {% endfor %}

      </div>

    </div>
  </section>


  <!-- ============================================================
       NEWSLETTER SIGNUP
       ============================================================ -->
  <section class="section section--sm" id="newsletter-signup" aria-labelledby="newsletter-heading">
    <div class="container">
      <div class="email-capture">
        <div class="email-capture__inner">
          <span class="label email-capture__label">Free Resource</span>
          <h2 id="newsletter-heading">Get new research delivered to your inbox</h2>
          <p>
            Plus receive a free personalized altitude performance report — covering your VO₂ max impact,
            acclimatization timeline, training adjustments, and nutrition strategy.
          </p>
          <form class="email-capture__form section-email-form" novalidate>
            <input
              type="email"
              class="form-input"
              placeholder="your@email.com"
              aria-label="Email address"
              required
            >
            <button type="submit" class="btn btn--primary">Get My Free Report</button>
          </form>
          <div class="success-msg" style="justify-content: center;">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8" fill="#3FB950"/><path d="M5 8l2 2 4-4" stroke="#0D1117" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            You're in! Your free report is on its way.
          </div>
          <p class="email-capture__disclaimer">
            No spam. Unsubscribe anytime.
          </p>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================================
       FOOTER
       ============================================================ -->
  <footer class="footer" role="contentinfo">
    <div class="container">
      <div class="footer__inner">

        <div class="footer__brand">
          <a href="/index.html" class="footer__logo" aria-label="Altitude Performance Lab home">
            <div class="footer__logo-mark">APL</div>
            <span class="footer__logo-text">Altitude<span>Performance</span>Lab</span>
          </a>
          <p>
            Science-backed tools and resources to help athletes understand and conquer
            altitude's impact on performance.
          </p>
          <a href="https://alturaperformance.com" class="footer__powered" target="_blank" rel="noopener">
            <span class="footer__powered-label">Powered by</span>
            Altura Performance
          </a>
        </div>

        <div>
          <div class="footer__col-title">Tools</div>
          <ul class="footer__links">
            <li><a href="/calculator/dist/index.html">Altitude Performance Calculator</a></li>
            <li><a href="/calculator/dist/index.html">Hydration Calculator</a></li>
            <li><a href="/calculator/dist/index.html">Nutrition Estimator</a></li>
          </ul>
        </div>

        <div>
          <div class="footer__col-title">Resources</div>
          <ul class="footer__links">
            <li><a href="/resources.html">Acclimatization Guides</a></li>
            <li><a href="/resources.html">Training</a></li>
            <li><a href="/resources.html">Nutrition &amp; Supplements</a></li>
            <li><a href="/resources.html">Science &amp; Research</a></li>
            <li><a href="/terms.html">Terms of Use</a></li>
          </ul>
        </div>

      </div>

      <div class="footer__bottom">
        <span class="footer__copyright">© {{ site.buildYear }} Altitude Performance Lab. All rights reserved.</span>
        <span class="footer__copyright"><a href="/terms.html" style="color: var(--text-muted); text-decoration: none;">Terms of Use</a></span>
      </div>
    </div>
  </footer>

  <!-- nav mobile toggle -->
  <script>
    (function () {
      var btn = document.getElementById('nav-hamburger');
      var menu = document.getElementById('nav-mobile');
      if (btn && menu) {
        btn.addEventListener('click', function () {
          var open = menu.classList.toggle('nav__mobile--open');
          btn.setAttribute('aria-expanded', open);
        });
      }
    })();
  </script>

  <!-- Article filter -->
  <script>
    (function () {
      var btns = document.querySelectorAll('.filter-btn');
      var cards = document.querySelectorAll('.article-card');

      btns.forEach(function (btn) {
        btn.addEventListener('click', function () {
          btns.forEach(function (b) { b.classList.remove('active'); });
          btn.classList.add('active');

          var filter = btn.dataset.filter;
          cards.forEach(function (card) {
            if (filter === 'all' || card.dataset.category === filter) {
              card.style.display = '';
            } else {
              card.style.display = 'none';
            }
          });
        });
      });
    })();
  </script>

</body>
</html>
